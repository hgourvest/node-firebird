{
    "name": "node-firebird",
    "version": "2.12.0",
    "description": "Pure JavaScript and Asynchronous Firebird client for Node.js.",
    "keywords": [
        "firebird",
        "database",
        "rdbms",
        "sql"
    ],
    "homepage": "https://github.com/hgourvest/node-firebird",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/hgourvest/node-firebird.git"
    },
    "author": {
        "name": "Henri Gourvest",
        "email": "hgourvest@gmail.com"
    },
    "contributors": [
        "Popa Marius Adrian <mapopa@gmail.com>",
        "Peter Širka <petersirka@gmail.com>"
    ],
    "main": "./lib/index.js",
    "types": "./lib/index.d.ts",
    "files": [
        "lib",
        "src"
    ],
    "license": "MPL-2.0",
    "scripts": {
        "build": "tsc -p tsconfig.json && node -e \"require('fs').copyFileSync('src/firebird.msg','lib/firebird.msg')\"",
        "prepare": "npm run build",
        "pretest": "npm run build",
        "typecheck": "tsc -p tsconfig.test.json",
        "test": "vitest run",
        "lint": "oxlint"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "coveralls-next": "^6.0.1",
        "oxlint": "^0.15.11",
        "typescript": "^7.0.2",
        "vitest": "^4.0.18"
    }
}
